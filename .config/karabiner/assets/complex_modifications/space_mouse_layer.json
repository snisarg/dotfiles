// ┌─────────────────────────────────────────────────────────────┐
// │ Key Index (reserved by this rule set)                       │
// ├─────────────────────────────────────────────────────────────┤
// │ Layer key  : Spacebar (hold ≥ 500 ms)                       │
// │ Tap key    : Spacebar (tap ≤ 250 ms)                        │
// │ Mouse move : e ↑  s ←  d ↓  f →                            │
// │ Scroll     : i ↑  k ↓  u ←  o →                            │
// │ Clicks     : j left-click  l right-click                    │
// └─────────────────────────────────────────────────────────────┘
{
  "title": "Space Mouse Layer",
  "rules": [
    {
      "description": "Hold Spacebar = mouse layer. ESDF=cursor, I=scroll↑, K=scroll↓, U=scroll←, O=scroll→, J=left-click, L=right-click. Tap alone = Space.",
      "manipulators": [

        // Spacebar: tap = space, hold ≥ 500ms = mouse layer
        {
          "type": "basic",
          "from": { "key_code": "spacebar", "modifiers": { "optional": ["any"] } },
          "parameters": {
            "basic.to_delayed_action_delay_milliseconds": 500,
            "basic.to_if_alone_timeout_milliseconds": 250
          },
          "to": [
            { "set_variable": { "name": "enter_mouse_layer", "value": 1 } },
            { "set_variable": { "name": "enter_printed", "value": 1 } }
          ],
          "to_after_key_up": [
            { "set_variable": { "name": "enter_mouse_layer", "value": 0 } }
          ],
          "to_delayed_action": {
            "to_if_canceled": [
              { "set_variable": { "name": "enter_mouse_layer", "value": 0 } },
              {
                "conditions": [{ "name": "enter_printed", "type": "variable_if", "value": 1 }],
                "key_code": "spacebar"
              },
              { "set_variable": { "name": "enter_printed", "value": 0 } }
            ]
          },
          "to_if_alone": [
            {
              "conditions": [{ "name": "enter_printed", "type": "variable_if", "value": 1 }],
              "key_code": "spacebar"
            },
            { "set_variable": { "name": "enter_printed", "value": 0 } }
          ]
        },

        // Mouse movement — ESDF
        { "type": "basic", "from": { "key_code": "e", "modifiers": { "optional": ["any"] } }, "to": [{ "mouse_key": { "y": -1536 } }], "conditions": [{ "type": "variable_if", "name": "enter_mouse_layer", "value": 1 }] },
        { "type": "basic", "from": { "key_code": "s", "modifiers": { "optional": ["any"] } }, "to": [{ "mouse_key": { "x": -1536 } }], "conditions": [{ "type": "variable_if", "name": "enter_mouse_layer", "value": 1 }] },
        { "type": "basic", "from": { "key_code": "d", "modifiers": { "optional": ["any"] } }, "to": [{ "mouse_key": { "y": 1536 } }],  "conditions": [{ "type": "variable_if", "name": "enter_mouse_layer", "value": 1 }] },
        { "type": "basic", "from": { "key_code": "f", "modifiers": { "optional": ["any"] } }, "to": [{ "mouse_key": { "x": 1536 } }],  "conditions": [{ "type": "variable_if", "name": "enter_mouse_layer", "value": 1 }] },

        // Scroll — I/K (up/down), U/O (left/right)
        { "type": "basic", "from": { "key_code": "i", "modifiers": { "optional": ["any"] } }, "to": [{ "mouse_key": { "vertical_wheel": -32 } }],   "conditions": [{ "type": "variable_if", "name": "enter_mouse_layer", "value": 1 }] },
        { "type": "basic", "from": { "key_code": "k", "modifiers": { "optional": ["any"] } }, "to": [{ "mouse_key": { "vertical_wheel": 32 } }],    "conditions": [{ "type": "variable_if", "name": "enter_mouse_layer", "value": 1 }] },
        { "type": "basic", "from": { "key_code": "u", "modifiers": { "optional": ["any"] } }, "to": [{ "mouse_key": { "horizontal_wheel": -32 } }], "conditions": [{ "type": "variable_if", "name": "enter_mouse_layer", "value": 1 }] },
        { "type": "basic", "from": { "key_code": "o", "modifiers": { "optional": ["any"] } }, "to": [{ "mouse_key": { "horizontal_wheel": 32 } }],  "conditions": [{ "type": "variable_if", "name": "enter_mouse_layer", "value": 1 }] },
        { "type": "basic", "from": { "key_code": "w", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "page_up" }],                       "conditions": [{ "type": "variable_if", "name": "enter_mouse_layer", "value": 1 }] },
        { "type": "basic", "from": { "key_code": "r", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "page_down" }],                     "conditions": [{ "type": "variable_if", "name": "enter_mouse_layer", "value": 1 }] },

        // Clicks — J (left) / L (right)
        { "type": "basic", "from": { "key_code": "j", "modifiers": { "optional": ["any"] } }, "to": [{ "pointing_button": "button1" }], "conditions": [{ "type": "variable_if", "name": "enter_mouse_layer", "value": 1 }] },
        { "type": "basic", "from": { "key_code": "l", "modifiers": { "optional": ["any"] } }, "to": [{ "pointing_button": "button2" }], "conditions": [{ "type": "variable_if", "name": "enter_mouse_layer", "value": 1 }] }

      ]
    }
  ]
}
